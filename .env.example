# Database
DATABASE_URL=postgresql://ekc_user:ekc_user@localhost:5432/ekc_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Ollama — point to host machine running Ollama
OLLAMA_BASE_URL=http://172.16.29.1:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT=90

# Security — change in production
JWT_SECRET_KEY=your-secret-key-minimum-32-characters-long
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# App
APP_ENV=development
APP_NAME=Enterprise Knowledge Copilot
APP_VERSION=1.0.0

# FAISS
FAISS_INDEX_PATH=data/indexes/faiss.index
BM25_INDEX_PATH=data/indexes/bm25.pkl

# Retrieval settings
VECTOR_TOP_K=5
BM25_TOP_K=5
GRAPH_TOP_K=5
RERANK_TOP_N=15
